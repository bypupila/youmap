NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://travelyourmap.bypupila.com
# Optional local-only visual feedback toolbar. Keep disabled unless actively testing it.
NEXT_PUBLIC_ENABLE_AGENTATION=0
# Optional local/staging-only no-payment creator activation. Keep unset in production.
ENABLE_TEST_NO_PAYMENT=0
# Optional PostHog local behavior
# 0: disable PostHog in development to avoid noisy network errors from ad-blockers/offline
# 1: enable PostHog in development
NEXT_PUBLIC_ENABLE_POSTHOG_IN_DEV=0
# 1: enable PostHog debug logs in browser console (off by default)
NEXT_PUBLIC_POSTHOG_DEBUG=0
# Optional Microsoft Clarity settings
# If NEXT_PUBLIC_CLARITY_PROJECT_ID is empty, Clarity script is not loaded.
NEXT_PUBLIC_CLARITY_PROJECT_ID=
# 1: enable Clarity in development (production uses Clarity if project ID is set)
NEXT_PUBLIC_ENABLE_CLARITY_IN_DEV=0

DATABASE_URL=postgresql://user:password@host/db?sslmode=require
AUTH_SESSION_SECRET=replace-with-long-random-secret
# Optional legacy alias. If set, app can use it instead of AUTH_SESSION_SECRET.
SESSION_SECRET=
NEON_PROJECT_ID=your-neon-project-id

# Required for real YouTube import + AI location extraction
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY
# Define one of these Gemini/Google GenAI keys (recommended: GOOGLE_GENAI_API_KEY)
GOOGLE_GENAI_API_KEY=YOUR_GEMINI_API_KEY
# Optional aliases if you already use them in other environments:
# GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# GOOGLE_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
# Optional import worker settings
YOUTUBE_IMPORT_WORKER_TOKEN=change-me-for-cron-worker
YOUTUBE_IMPORT_CONCURRENCY=3
YOUTUBE_IMPORT_MAX_VIDEOS_PER_RUN=2500
# Optional map poll auto-close auth token (used by /api/map/polls/close-expired)
MAP_POLLS_CRON_TOKEN=
# Required in production when using Vercel Cron GET invocations.
# Vercel sends it as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=
# Required for Nominatim identification (geocoding for map coordinates)
NOMINATIM_USER_AGENT=TravelYourMap
NOMINATIM_EMAIL=you@example.com

# Required for PostHog analytics
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Required only for Polar billing flows
POLAR_ACCESS_TOKEN=polar_...
POLAR_WEBHOOK_SECRET=polar_whs_...
# Optional checkout discount ID applied to trial checkout session
POLAR_TRIAL_DISCOUNT_ID=

# Optional transactional email provider
RESEND_API_KEY=
