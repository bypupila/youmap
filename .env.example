NEXT_PUBLIC_APP_URL=http://localhost:3000

DATABASE_URL=postgresql://user:password@host/db?sslmode=require
AUTH_SESSION_SECRET=replace-with-long-random-secret
# Optional legacy alias. If set, app can use it instead of AUTH_SESSION_SECRET.
SESSION_SECRET=
NEON_PROJECT_ID=your-neon-project-id

# Required for real YouTube import + AI location extraction
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY
# Define one of these Gemini/Google GenAI keys (recommended: GOOGLE_GENAI_API_KEY)
GOOGLE_GENAI_API_KEY=YOUR_GEMINI_API_KEY
# Optional aliases if you already use them in other environments:
# GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# GOOGLE_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
# Optional import worker settings
YOUTUBE_IMPORT_WORKER_TOKEN=change-me-for-cron-worker
YOUTUBE_IMPORT_CONCURRENCY=3
YOUTUBE_IMPORT_MAX_VIDEOS_PER_RUN=2500
# Required for Nominatim identification (geocoding for map coordinates)
NOMINATIM_USER_AGENT=TravelMap
NOMINATIM_EMAIL=you@example.com

# Required only for Polar billing flows
POLAR_ACCESS_TOKEN=polar_...
POLAR_WEBHOOK_SECRET=polar_whs_...
# Optional checkout discount ID applied to trial checkout session
POLAR_TRIAL_DISCOUNT_ID=
